[Remote Script]
https://raw.githubusercontent.com/NobyDa/Script/master/Loon/Loon_Daily_bonus.plugin, tag=tb, enabled=true

[Script]
cron "0 18 * * *" script-path=https://raw.githubusercontent.com/Serein1202/Loon/refs/heads/main/Scripts/Oil/Oil.js, timeout=60, tag=今日油价
cron "5 0 * * *" script-path=https://raw.githubusercontent.com/evilbutcher/QuantumultX/master/check_in/glados/checkincookie_env.js, timeout=300, tag=机场签到Cookie版
cron "5 10 * * *" script-path=https://raw.githubusercontent.com/evilbutcher/QuantumultX/master/check_in/glados/checkin_env.js, timeout=60, tag=ikuuu每日签到
http-request ^https?:\/\/(c\.tieba|tiebac)\.baidu\.com\/c\/s\/login script-path=https://raw.githubusercontent.com/NobyDa/Script/master/BDTieBa-DailyBonus/TieBa.js, timeout=60, tag=贴吧获取cookies
cron "40 8 * * *" script-path=https://raw.githubusercontent.com/NobyDa/Script/master/BDTieBa-DailyBonus/TieBa.js, timeout=60, tag=贴吧签到
cron "1 0 * * *" script-path=https://raw.githubusercontent.com/wf021325/qx/master/task/ampDache.js, timeout=10, tag=高德签到
