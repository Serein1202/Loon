[Rule]

[Rewrite]
# 去广告
^https?:\/\/a\.sinopecsales\.com\/app\/wff reject
^https?:\/\/shop\.ejoy365\.com\/ejoyshop-product\/front\/product\/integral\/selectList reject
^https?:\/\/pro-ocr\.oss-cn-beijing\.aliyuncs\.com\/+swt reject
^https?:\/\/ejoyshopbucket\.oss-cn-beijing\.aliyuncs\.com\/group1\/pic reject
^https?:\/\/d\.sinopecsales\.com\/third\/netadmin\/static\/imgs reject
^https?:\/\/a\.sinopecsales\.com\/app\/cms reject


[Script]

[MITM]
hostname = shop.ejoy365.com,a.sinopecsales.com,d.sinopecsales.com,pro-ocr.oss-cn-beijing.aliyuncs.com,ejoyshopbucket.oss-cn-beijing.aliyuncs.com


