[Rule]

[Rewrite]
# 去广告
^https?:\/\/a\.sinopecsales\.com\/app\/wff reject-200
^https?:\/\/shop\.ejoy365\.com\/ejoyshop-product\/front\/product\/integral\/selectList reject-200
^https?:\/\/pro-ocr\.oss-cn-beijing\.aliyuncs\.com\/+swt reject-200
